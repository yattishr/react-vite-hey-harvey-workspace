# Existing server configuration
DATABASE_URL=
OPENAI_API_KEY=

# Node reads CA settings before dotenv loads. The repository's dev/start/smoke
# scripts set NODE_USE_SYSTEM_CA=1 so Windows enterprise CAs remain verified.
# If your deployment bypasses those scripts, set NODE_USE_SYSTEM_CA=1 in the
# process environment before starting Node. Never use NODE_TLS_REJECT_UNAUTHORIZED=0.

# V1.2 OpenAI Agents SDK runtime. Keep disabled until migration 0004 is applied.
OPENAI_AGENTS_RUNTIME_ENABLED=false
OPENAI_AGENTS_TRACING_ENABLED=true
OPENAI_AGENTS_DEFAULT_MODEL=gpt-4o-mini
OPENAI_AGENTS_MAX_TURNS=8
OPENAI_AGENTS_STEP_TIMEOUT_MS=90000
OPENAI_AGENTS_RUN_TIMEOUT_MS=300000
OPENAI_AGENTS_MAX_STEP_RETRIES=1
